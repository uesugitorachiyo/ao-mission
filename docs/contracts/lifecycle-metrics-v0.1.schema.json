{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ao.mission.lifecycle-metrics.v0.1",
  "type": "object",
  "required": [
    "schema",
    "mission_id",
    "status",
    "handoff_steps",
    "evidence_completed_nodes",
    "completed_nodes",
    "total_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "completion_basis",
    "handoff_steps_count_as_completed_nodes",
    "final_response_allowed",
    "return_gate_status",
    "exact_next_action",
    "safe_to_execute",
    "executes_work",
    "approves_work",
    "mutates_repositories",
    "rsi_remains_denied",
    "generated_at_utc"
  ],
  "properties": {
    "schema": { "type": "string", "const": "ao.mission.lifecycle-metrics.v0.1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "const": "audited" },
    "handoff_steps": { "type": "integer", "minimum": 0 },
    "evidence_completed_nodes": { "type": "integer", "minimum": 0 },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "total_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "completion_basis": { "type": "string", "const": "downstream_evidence_not_handoff_steps" },
    "handoff_steps_count_as_completed_nodes": { "type": "boolean", "const": false },
    "final_response_allowed": { "type": "boolean" },
    "return_gate_status": { "type": "string" },
    "exact_next_action": { "type": "string" },
    "safe_to_execute": { "type": "boolean", "const": false },
    "executes_work": { "type": "boolean", "const": false },
    "approves_work": { "type": "boolean", "const": false },
    "mutates_repositories": { "type": "boolean", "const": false },
    "rsi_remains_denied": { "type": "boolean", "const": true },
    "generated_at_utc": { "type": "string" }
  }
}
