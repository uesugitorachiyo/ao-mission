{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ao.mission.correlation-chain.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "mission_id",
    "correlation_id",
    "entries",
    "safe_to_execute",
    "executes_work",
    "approves_work",
    "mutates_repositories",
    "widens_policy",
    "publishes_artifacts"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "ao.mission.correlation-chain.v0.1"
    },
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "digest",
          "producer",
          "binding_mode",
          "safe_to_execute",
          "executes_work",
          "approves_work",
          "mutates_repositories",
          "widens_policy",
          "publishes_artifacts"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          },
          "artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_name": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "producer": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          },
          "binding_mode": {
            "type": "string",
            "enum": ["native_field", "digest_link"]
          },
          "native_identifier": {
            "type": "string",
            "minLength": 1
          },
          "native_field": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:/(?:[^~/]|~[01])*)+$",
            "description": "RFC 6901 JSON Pointer to the exact native identifier field."
          },
          "parent_role": {
            "type": "string",
            "minLength": 1
          },
          "parent_digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "parent_digest_field": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:/(?:[^~/]|~[01])*)+$",
            "description": "RFC 6901 JSON Pointer to the exact parent digest field."
          },
          "safe_to_execute": {
            "type": "boolean",
            "const": false
          },
          "executes_work": {
            "type": "boolean",
            "const": false
          },
          "approves_work": {
            "type": "boolean",
            "const": false
          },
          "mutates_repositories": {
            "type": "boolean",
            "const": false
          },
          "widens_policy": {
            "type": "boolean",
            "const": false
          },
          "publishes_artifacts": {
            "type": "boolean",
            "const": false
          }
        },
        "oneOf": [
          {
            "required": ["artifact_path"],
            "not": { "required": ["artifact_name"] }
          },
          {
            "required": ["artifact_name"],
            "not": { "required": ["artifact_path"] }
          }
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "binding_mode": { "const": "native_field" }
              }
            },
            "then": {
              "required": ["native_identifier", "native_field"],
              "not": {
                "anyOf": [
                  { "required": ["parent_role"] },
                  { "required": ["parent_digest"] },
                  { "required": ["parent_digest_field"] }
                ]
              }
            },
            "else": {
              "required": ["parent_role", "parent_digest", "parent_digest_field"],
              "not": {
                "anyOf": [
                  { "required": ["native_identifier"] },
                  { "required": ["native_field"] }
                ]
              }
            }
          }
        ]
      }
    },
    "safe_to_execute": {
      "type": "boolean",
      "const": false
    },
    "executes_work": {
      "type": "boolean",
      "const": false
    },
    "approves_work": {
      "type": "boolean",
      "const": false
    },
    "mutates_repositories": {
      "type": "boolean",
      "const": false
    },
    "widens_policy": {
      "type": "boolean",
      "const": false
    },
    "publishes_artifacts": {
      "type": "boolean",
      "const": false
    }
  }
}
