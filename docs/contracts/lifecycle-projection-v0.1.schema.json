{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/contracts/lifecycle-projection-v0.1.schema.json",
  "title": "AO Mission lifecycle projection",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "mission_status",
    "metrics",
    "event_count",
    "event_index_digest",
    "source_record_digest",
    "source_record_updated_at",
    "final_response_allowed",
    "exact_next_action",
    "safe_to_execute",
    "executes_work",
    "approves_work",
    "mutates_repositories",
    "rsi_remains_denied",
    "generated_at_utc"
  ],
  "properties": {
    "schema": { "const": "ao.mission.lifecycle-projection.v0.1" },
    "status": { "const": "ready" },
    "mission_id": { "type": "string", "minLength": 1 },
    "mission_status": { "type": "string", "minLength": 1 },
    "current_phase": { "type": "string" },
    "current_route": { "type": "string" },
    "latest_route": { "type": "string" },
    "metrics": { "$ref": "lifecycle-metrics-v0.1.schema.json" },
    "event_count": { "type": "integer", "minimum": 0 },
    "event_index_digest": { "type": "string", "pattern": "^sha256:" },
    "source_record_digest": { "type": "string", "pattern": "^sha256:" },
    "source_record_updated_at": { "type": "string", "minLength": 1 },
    "final_response_allowed": { "type": "boolean" },
    "exact_next_action": { "type": "string" },
    "safe_to_execute": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "mutates_repositories": { "const": false },
    "rsi_remains_denied": { "const": true },
    "generated_at_utc": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
